# ─── Pi SDK / LLM provider credentials ────────────────────────────────────────
# The service uses the real Pi TypeScript SDK (@earendil-works/pi-coding-agent).
# Pi resolves a provider API key from the environment. Provide ONE provider key.
# Without a valid key the service FAILS FAST at startup (no mock fallback).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model the agent loop should use (provider-qualified id understood by Pi).
PI_MODEL=claude-sonnet-4-6

# Optional: override Pi config/auth directory.
# PI_CODING_AGENT_DIR=/var/lib/pi

# ─── Kubernetes ───────────────────────────────────────────────────────────────
# Namespace that holds the sandbox StatefulSet + the 8 Lease objects.
SANDBOX_NAMESPACE=pi-sandbox
# Number of warm sandbox pods (fixed at 8 for this assignment).
SANDBOX_POOL_SIZE=8
# StatefulSet pod name prefix -> sandbox-runner-0 .. sandbox-runner-7
SANDBOX_POD_PREFIX=sandbox-runner
# Container name inside each sandbox pod to exec into.
SANDBOX_CONTAINER=runner
# Path to a kubeconfig. If empty, in-cluster config is used when running in-pod.
# KUBECONFIG=/Users/you/.kube/config

# ─── Timeouts / lease tuning (seconds) ────────────────────────────────────────
MAX_QUEUE_WAIT_SECONDS=15
TOOL_EXECUTION_TIMEOUT_SECONDS=30
LEASE_TTL_SECONDS=45

# ─── Service identity / server ────────────────────────────────────────────────
# Stable per-replica id, recorded in Lease holderIdentity for debuggability.
SERVICE_INSTANCE_ID=api-1
PORT=3000
LOG_LEVEL=info

# fs.read allowed root inside the sandbox pod (path allowlist root).
SANDBOX_FS_ROOT=/workspace
